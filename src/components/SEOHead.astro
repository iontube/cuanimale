---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: string;
  ogImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  publishedTime?: string;
  modifiedTime?: string;
  noindex?: boolean;
  jsonLd?: string[];
}

const {
  title,
  description,
  canonical,
  ogType = 'website',
  ogImage,
  ogImageWidth = 1200,
  ogImageHeight = 630,
  publishedTime,
  modifiedTime,
  noindex = false,
  jsonLd = [],
} = Astro.props;

const siteUrl = 'https://cuanimale.ro';
const fullCanonical = canonical ? `${siteUrl}${canonical}` : `${siteUrl}${Astro.url.pathname}`;
const fullTitle = title.length > 55 || title.includes('Cu Animale') ? title : `${title} | Cu Animale`;
const fullOgImage = ogImage ? `${siteUrl}${ogImage}` : `${siteUrl}/og-default.png`;
const now = new Date().toISOString();
const modifiedIso = modifiedTime || now;
---

<!-- Primary Meta -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={fullCanonical} />
{noindex ? <meta name="robots" content="noindex, nofollow" /> : <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="article:modified_time" content={modifiedIso} />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={fullCanonical} />
<meta property="og:site_name" content="Cu Animale" />
<meta property="og:locale" content="ro_RO" />
<meta property="og:image" content={fullOgImage} />
<meta property="og:image:width" content={String(ogImageWidth)} />
<meta property="og:image:height" content={String(ogImageHeight)} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullOgImage} />

<!-- JSON-LD -->
{jsonLd.map(schema => (
  <script type="application/ld+json" set:html={schema} />
))}
