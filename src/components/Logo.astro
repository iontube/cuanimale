---
interface Props {
  variant?: 'light' | 'dark';
}
const { variant = 'light' } = Astro.props;
---

<picture>
  <source srcset="/logo.webp" type="image/webp" />
  <img
    src="/logo.png"
    alt="cuanimale.ro - Animale de companie"
    class="h-12 w-auto"
    width="600"
    height="400"
    loading="eager"
    fetchpriority="high"
    data-variant={variant}
  />
</picture>
