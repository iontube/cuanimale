---
interface Props {
  variant?: 'light' | 'dark';
  size?: 'header' | 'footer';
}
const { variant = 'light', size = 'header' } = Astro.props;
const sizeClass = size === 'footer'
  ? 'h-28 sm:h-32 w-auto'
  : 'h-28 sm:h-24 w-auto';
---

<picture>
  <source srcset="/logo.webp" type="image/webp" />
  <img
    src="/logo.png"
    alt="cuanimale.ro - Animale de companie"
    class={sizeClass}
    width="600"
    height="400"
    loading={size === 'header' ? 'eager' : 'lazy'}
    fetchpriority={size === 'header' ? 'high' : 'auto'}
    data-variant={variant}
  />
</picture>
