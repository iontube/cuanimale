---
import Layout from '../../../layouts/Layout.astro';
import SEOHead from '../../../components/SEOHead.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { getAllIntrebari, getAnimalBySlug, getSubcategorieBySlug, getIntrebariRelate } from '../../../helpers/data';
import { getSiblingSubcategorii, getSubcategorieFAQLinks, getCitesteLinks } from '../../../helpers/interlinking';
import { buildArticleSchema, buildBreadcrumbSchema, buildFAQSchema } from '../../../helpers/structured-data';
import type { Intrebare, BreadcrumbItem } from '../../../helpers/types';

export function getStaticPaths() {
  const allIntrebari = getAllIntrebari();
  return allIntrebari.map(q => ({
    params: { animal: q.animalSlug, subcategorie: q.subcategorieSlug, intrebare: q.slug },
    props: { intrebare: q },
  }));
}

const { intrebare } = Astro.props as { intrebare: Intrebare };
const animal = getAnimalBySlug(intrebare.animalSlug)!;
const subcategorie = getSubcategorieBySlug(intrebare.animalSlug, intrebare.subcategorieSlug)!;
const relatedIntrebari = getIntrebariRelate(intrebare);
const siblingSubcats = getSiblingSubcategorii(intrebare.animalSlug, intrebare.subcategorieSlug);
const moreFAQs = getSubcategorieFAQLinks(intrebare.animalSlug, intrebare.subcategorieSlug, 6)
  .filter(l => !l.href.includes(intrebare.slug));

// Relevant "Citește și" links with full title
const citesteLinks = getCitesteLinks(intrebare);

const pageUrl = `/${intrebare.animalSlug}/${intrebare.subcategorieSlug}/${intrebare.slug}/`;

const breadcrumbItems: BreadcrumbItem[] = [
  { label: animal.numePlural, href: `/${animal.slug}/` },
  { label: subcategorie.nume, href: `/${animal.slug}/${subcategorie.slug}/` },
  { label: intrebare.titlu },
];

// Build FAQ schema from article's own sections (Q = title, A = intro)
const faqItems = [{
  intrebare: intrebare.titlu,
  raspuns: intrebare.intro,
}];
---

<Layout>
  <SEOHead
    slot="head"
    title={intrebare.metaTitle}
    description={intrebare.metaDescription}
    canonical={pageUrl}
    ogType="article"
    jsonLd={[
      buildArticleSchema(intrebare, pageUrl),
      buildBreadcrumbSchema([{ label: 'Acasă', href: '/' }, ...breadcrumbItems]),
      ...(faqItems.length > 0 ? [buildFAQSchema(faqItems)] : []),
    ]}
  />

  <article class="container-narrow py-8">
    <Breadcrumb items={breadcrumbItems} />

    <!-- Header -->
    <header class="mb-8">
      <div class="flex flex-wrap gap-2 mb-3">
        <a href={`/${animal.slug}/`} class="badge badge-brand no-underline">{animal.numePlural}</a>
        <a href={`/${animal.slug}/${subcategorie.slug}/`} class="badge badge-success no-underline">{subcategorie.nume}</a>
        {intrebare.rasa && <span class="badge badge-warning">{intrebare.rasa}</span>}
      </div>
      <h1 class="text-2xl sm:text-3xl font-heading font-extrabold text-surface-900 leading-tight">
        {intrebare.titlu}
      </h1>
    </header>

    <!-- Intro -->
    <div class="prose-custom mb-8">
      <p class="text-lg text-surface-700 leading-relaxed">{intrebare.intro}</p>
    </div>

    <!-- Content sections -->
    {intrebare.sectiuni.map(sectiune => (
      <section class="mb-8">
        <h2 class="text-xl font-heading font-bold text-surface-900 mb-4">{sectiune.titlu}</h2>
        {sectiune.tip === 'pasi' ? (
          <ol class="space-y-3">
            {sectiune.items.map((item, i) => (
              <li class="flex gap-3">
                <span class="flex-shrink-0 w-7 h-7 rounded-full bg-brand-100 text-brand-700 text-sm font-bold flex items-center justify-center mt-0.5">
                  {i + 1}
                </span>
                <div>
                  {item.titlu && <strong class="text-surface-900 block mb-0.5">{item.titlu}</strong>}
                  <span class="text-surface-700">{item.text}</span>
                </div>
              </li>
            ))}
          </ol>
        ) : sectiune.tip === 'lista' ? (
          <ul class="space-y-3">
            {sectiune.items.map(item => (
              <li class="flex gap-3">
                <span class="flex-shrink-0 w-1.5 h-1.5 rounded-full bg-brand-500 mt-2.5"></span>
                <div>
                  {item.titlu && <strong class="text-surface-900 block mb-0.5">{item.titlu}</strong>}
                  <span class="text-surface-700">{item.text}</span>
                </div>
              </li>
            ))}
          </ul>
        ) : (
          <div class="prose-custom">
            {sectiune.items.map(item => (
              <p>{item.text}</p>
            ))}
          </div>
        )}
      </section>
    ))}

    <!-- Conclusion -->
    <div class="bg-brand-50 border border-brand-200 rounded-card p-5 mb-8">
      <p class="text-surface-800 leading-relaxed">{intrebare.concluzie}</p>
    </div>

    <!-- Citește și - relevant links with full titles -->
    {citesteLinks.length > 0 && (
      <section class="mb-10">
        <h2 class="text-lg font-heading font-semibold text-surface-900 mb-4">Citește și</h2>
        <div class="space-y-2">
          {citesteLinks.map(link => (
            <a
              href={link.href}
              class="card p-3 no-underline group flex items-center justify-between"
            >
              <span class="text-sm font-medium text-surface-800 group-hover:text-brand-600 transition-colors">{link.text}</span>
              <svg aria-hidden="true" class="w-4 h-4 text-surface-400 group-hover:text-brand-500 shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- More from subcategory -->
    {moreFAQs.length > 0 && (
      <section class="mb-10">
        <h2 class="text-lg font-heading font-semibold text-surface-900 mb-4">Mai multe despre {subcategorie.nume.toLowerCase()}</h2>
        <div class="space-y-2">
          {moreFAQs.slice(0, 4).map(link => (
            <a href={link.href} class="card p-3 no-underline group flex items-center justify-between">
              <span class="text-sm font-medium text-surface-800 group-hover:text-brand-600 transition-colors">{link.text}</span>
              <svg aria-hidden="true" class="w-4 h-4 text-surface-400 group-hover:text-brand-500 shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ))}
        </div>
        <a href={`/${animal.slug}/${subcategorie.slug}/`} class="text-link text-sm mt-3 inline-block">
          Toate articolele despre {subcategorie.nume.toLowerCase()} →
        </a>
      </section>
    )}

    <!-- Other subcategories -->
    <section class="pt-8 border-t border-surface-200">
      <h2 class="text-lg font-heading font-semibold text-surface-900 mb-4">Alte subiecte despre {animal.numePlural.toLowerCase()}</h2>
      <div class="flex flex-wrap gap-2">
        {siblingSubcats.map(link => (
          <a href={link.href} class="badge badge-brand no-underline hover:bg-brand-200 transition-colors">
            {link.text}
          </a>
        ))}
      </div>
    </section>
  </article>
</Layout>
